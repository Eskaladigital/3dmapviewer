{
  "name": "floorcraft",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:3000 && cross-env VITE_DEV_SERVER_URL=http://localhost:3000 electron .\"",
    "electron:build": "node scripts/prebuild.cjs && vite build && electron-builder --win"
  },
  "build": {
    "appId": "com.floorcraft.app",
    "productName": "FloorCraft",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "dist/**"
    ],
    "win": {
      "target": "dir",
      "signAndEditExecutable": false
    }
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@react-three/drei": "^9.97.0",
    "@react-three/fiber": "^8.15.16",
    "@react-three/postprocessing": "^2.16.2",
    "dxf-parser": "^1.1.2",
    "express": "^5.2.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.577.0",
    "pdfjs-dist": "^5.4.624",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.162.0",
    "uuid": "^9.0.0",
    "zustand": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.162.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.4.2",
    "vite": "^5.1.4",
    "wait-on": "^9.0.4"
  }
}
